# Clarafy environment variables
# Copy this file to .env.local and fill in your values. Never commit .env.local.

# Anthropic API key — required for translation.
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-placeholder-paste-your-key-here

# Model to use. Sonnet is the recommended default for this workload —
# it handles long legal documents with structure preservation well.
CLAUDE_MODEL=claude-sonnet-4-6

# Public site URL (used for canonical links, og tags)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
